    <script>
  let formOpen = false;
  let currentRating = 0;

  function toggleForm() {
    formOpen = !formOpen;
    const el = document.getElementById('feedback-form');
    const chevron = document.getElementById('form-chevron');
    el.style.display = formOpen ? 'block' : 'none';
    chevron.style.transform = formOpen ? 'rotate(180deg)' : '';
  }

  function setRating(val) {
    currentRating = val;
    document.getElementById('f-rating').value = val;
    const btns = document.querySelectorAll('.star-btn');
    btns.forEach((b, i) => {
      b.style.opacity = i < val ? '1' : '0.3';
    });
  }

  function submitFeedback() {
    const name = document.getElementById('f-name').value.trim();
    const plant = document.getElementById('f-plant').value.trim();
    const comment = document.getElementById('f-comment').value.trim();
    const rating = parseInt(document.getElementById('f-rating').value);
    const msg = document.getElementById('form-msg');

    if (!name || !plant || !comment || !rating) {
      msg.style.display = 'block';
      msg.style.color = '#f87171';
      msg.textContent = '⚠ Preencha todos os campos obrigatórios.';
      return;
    }

    // Simulated success (no backend in static version)
    msg.style.display = 'block';
    msg.style.color = '#3dba6a';
    msg.textContent = '✓ Feedback enviado com sucesso! (versão estática)';
    document.getElementById('f-name').value = '';
    document.getElementById('f-plant').value = '';
    document.getElementById('f-comment').value = '';
    document.getElementById('f-rating').value = 0;
    setRating(0);
  }

  function filterFeedbacks(env) {
    const cards = document.querySelectorAll('#feedback-list .card-anim');
    cards.forEach(card => {
      card.style.display = (env === 'all' || card.dataset.env === env) ? 'block' : 'none';
    });
  }

  function filterResearch(env) {
    const cards = document.querySelectorAll('#research-list .card-anim');
    cards.forEach(card => {
      card.style.display = (env === 'all' || card.dataset.env === env) ? 'block' : 'none';
    });
  }
